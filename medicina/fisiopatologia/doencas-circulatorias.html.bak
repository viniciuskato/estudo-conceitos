<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Patologia das Doenças Circulatórias</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#111010;--bg2:#1a1919;--bg3:#222121;--border:#333131;
  --text:#e2ddd6;--muted:#9e9890;
  --ac:#d4924a;--ac2:#c0604a;--ac2bg:#2a1810;
  --font-body:'Source Serif 4',Georgia,serif;
  --font-ui:'Inter',system-ui,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:16px;line-height:1.78;display:flex;min-height:100vh;flex-direction:column}

/* ── MOB BAR ── */
#mob-bar{display:none;align-items:center;justify-content:space-between;padding:10px 16px;background:var(--bg2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50}
#mob-bar .mb-title{font-family:var(--font-ui);font-size:13px;font-weight:500;color:var(--text)}
#mob-btn{background:none;border:1px solid var(--border);border-radius:5px;padding:5px 12px;color:var(--muted);font-family:var(--font-ui);font-size:12px;cursor:pointer}

/* ── LAYOUT ── */
#body-wrap{display:flex;flex:1;min-height:0}

/* ── SIDEBAR ── */
#sidebar{width:280px;background:var(--bg2);border-right:1px solid var(--border);height:100vh;position:sticky;top:0;display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;transition:width .25s}
#sidebar.collapsed{width:44px}
#s-toggle{padding:10px 10px 0;display:flex;justify-content:flex-end;flex-shrink:0}
#toggle-btn{background:none;border:1px solid var(--border);border-radius:4px;width:26px;height:26px;cursor:pointer;color:var(--muted);font-size:14px;display:flex;align-items:center;justify-content:center;font-family:var(--font-ui)}
.s-inner{flex:1;overflow-y:auto;width:280px;padding:14px 0 40px}
.s-logo{padding:8px 16px 14px;border-bottom:1px solid var(--border);margin-bottom:10px}
.s-logo a{font-family:var(--font-ui);font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.06em;text-transform:uppercase}
.s-group{margin-bottom:18px;padding:0 10px}
.s-group-title{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;padding:0 6px;margin-bottom:6px}
a.sl{display:block;font-family:var(--font-ui);font-size:12px;color:var(--muted);text-decoration:none;padding:5px 10px;border-radius:4px;transition:background .15s,color .15s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
a.sl:hover,a.sl.active{background:var(--bg3);color:var(--text)}
a.sl.active{color:var(--ac)}
#sidebar.collapsed .s-logo,#sidebar.collapsed .s-group,#sidebar.collapsed .s-inner a.sl{opacity:0;pointer-events:none}

/* ── PROGRESS BAR ── */
#progress-bar{position:fixed;top:0;left:0;height:2px;background:var(--ac);z-index:100;width:0%;transition:width .1s}

/* ── CONTENT ── */
#content{flex:1;padding:52px 72px 120px;min-width:0;transition:padding .25s}
#body-wrap.sidebar-collapsed #content{padding:52px 100px 120px}
.prose{max-width:88ch;margin:0 auto;transition:max-width .25s}
#body-wrap.sidebar-collapsed .prose{max-width:114ch}

/* ── TYPOGRAPHY ── */
h1{font-size:2rem;font-weight:600;line-height:1.25;margin-bottom:10px;color:var(--text)}
h2{font-size:1.35rem;font-weight:600;color:var(--muted);margin:56px 0 18px;padding-top:10px;border-top:1px solid var(--border);transition:color .3s}
h3{font-size:1.05rem;font-weight:600;color:var(--text);margin:32px 0 12px}
h4{font-size:.95rem;font-weight:600;color:var(--ac);margin:24px 0 8px;font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.06em;font-size:.8rem}
p{margin-bottom:18px}
ul,ol{margin:0 0 18px 22px}
li{margin-bottom:6px}
em{font-style:italic}
strong{font-weight:600;color:var(--text)}
section.in-view > h2{color:var(--ac)}
table{width:100%;border-collapse:collapse;margin:20px 0 24px;font-size:14px}
th{background:var(--bg3);color:var(--ac);font-family:var(--font-ui);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border)}
td{padding:8px 12px;border-bottom:1px solid var(--border);vertical-align:top}
tr:last-child td{border-bottom:none}
.table-caption{font-family:var(--font-ui);font-size:12px;color:var(--muted);margin-top:-16px;margin-bottom:24px;font-style:italic}

/* ── COMPONENTES ── */
.doc-meta{font-family:var(--font-ui);font-size:13px;color:var(--muted);margin-bottom:14px}
.doc-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:40px}
.chip{font-family:var(--font-ui);font-size:11px;color:var(--muted);background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:3px 10px}
.pergunta{background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--ac);border-radius:0 6px 6px 0;padding:16px 20px;margin-bottom:40px}
.pergunta .plabel{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--ac);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.dep-panel{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:14px 18px;margin-bottom:40px}
.dep-panel .dep-label{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:12px}
.dep-row{display:flex;gap:10px;flex-wrap:wrap}
.dep-group{flex:1;min-width:160px}
.dep-group .dgt{font-family:var(--font-ui);font-size:10px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.06em}
.dep-item{font-family:var(--font-ui);font-size:12px;color:var(--muted);text-decoration:none;display:block;padding:3px 0;border-bottom:1px dashed var(--border)}
.hist{background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:12px 16px;margin:0 0 20px;font-size:14px;font-family:var(--font-ui);color:var(--muted)}
.hist .hl{font-size:9px;font-weight:600;color:var(--ac);text-transform:uppercase;letter-spacing:.09em;display:block;margin-bottom:5px}
.kbox{background:var(--ac2bg);border-left:2px solid var(--ac2);border-radius:0 5px 5px 0;padding:12px 16px;margin:14px 0}
.kbox .klabel{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--ac2);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px}
.ck-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}
.ck-card{background:var(--bg2);border:1px solid var(--border);border-radius:5px;padding:10px 13px}
.ck-card .ckt{font-family:var(--font-ui);font-size:12px;font-weight:600;color:var(--ac2);margin-bottom:4px}
.ck-card p{font-family:var(--font-ui);font-size:12px;color:var(--muted);margin:0}
a.cross-link{color:var(--ac);font-size:.85em;font-style:italic;border-bottom:1px dashed var(--ac);text-decoration:none;opacity:.9}
.qa-block{background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--muted);border-radius:0 6px 6px 0;padding:14px 18px;margin:10px 0}
.qa-block .qa-label{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.qa-block p{margin:0;color:var(--muted);font-size:15px}
.cite{color:var(--ac);font-size:.88em}
.ref-list{font-size:14px;line-height:1.7}
.ref-list p{margin-bottom:10px}
.ref-list a{color:var(--ac)}

/* ── MOBILE ── */
@media(max-width:900px){
  #mob-bar{display:flex}
  #sidebar{display:none;position:fixed;top:0;left:0;height:100vh;z-index:40}
  #sidebar.open{display:flex}
  #s-toggle{display:none}
  #content{padding:24px 20px 80px}
  .ck-grid{grid-template-columns:repeat(2,1fr)}
  h1{font-size:1.5rem}
}

/* ── PRINT ── */
@media print{
  #sidebar,#mob-bar,#progress-bar,#s-toggle{display:none!important}
  body{background:#fff;color:#000}
  a.cross-link::after{content:" (" attr(href) ")";font-size:.75em}
}
</style>
</head>
<body>
<div id="progress-bar"></div>

<div id="mob-bar">
  <span class="mb-title">Doenças Circulatórias</span>
  <button id="mob-btn" onclick="document.getElementById('sidebar').classList.toggle('open')">☰ Índice</button>
</div>

<div id="body-wrap">

<!-- ══ SIDEBAR ══ -->
<nav id="sidebar">
  <div id="s-toggle">
    <button id="toggle-btn" title="Colapsar sidebar">‹</button>
  </div>
  <div class="s-inner">
    <div class="s-logo"><a href="../../index.html">← Voltar ao índice</a></div>

    <div class="s-group">
      <div class="s-group-title">Introdução</div>
      <a class="sl" href="#pergunta">Pergunta motivadora</a>
      <a class="sl" href="#dependencias">Dependências</a>
      <a class="sl" href="#fundamentos">Fundamentos necessários</a>
      <a class="sl" href="#conceitos-chave">Conceitos-chave</a>
    </div>

    <div class="s-group">
      <div class="s-group-title">Distúrbios hemodinâmicos</div>
      <a class="sl" href="#congestion">Congestão</a>
      <a class="sl" href="#edema">Edema</a>
    </div>

    <div class="s-group">
      <div class="s-group-title">Hemostasia e trombose</div>
      <a class="sl" href="#hemostasia">Hemostasia</a>
      <a class="sl" href="#trombose">Trombose</a>
      <a class="sl" href="#embolia">Embolia</a>
    </div>

    <div class="s-group">
      <div class="s-group-title">Lesão vascular crônica</div>
      <a class="sl" href="#aterosclerose">Aterosclerose</a>
      <a class="sl" href="#infarto">Infarto</a>
    </div>

    <div class="s-group">
      <div class="s-group-title">Fechamento</div>
      <a class="sl" href="#conexoes">Conexões</a>
      <a class="sl" href="#perguntas-abertas">Perguntas em aberto</a>
      <a class="sl" href="#discussao">Discussão</a>
      <a class="sl" href="#leituras">Leituras recomendadas</a>
      <a class="sl" href="#referencias">Referências</a>
    </div>
  </div>
</nav>

<!-- ══ CONTENT ══ -->
<main id="content">
<article class="prose">

<div class="doc-header">
  <h1>Patologia das Doenças Circulatórias</h1>
  <p class="doc-meta">Medicina · Patologia · Fisiopatologia · 2026</p>
  <div class="doc-chips">
    <span class="chip">⏱ <b>~90 min</b> de leitura</span>
    <span class="chip">📋 Pré-requisitos: <b>Histologia vascular, fisiologia cardíaca básica</b></span>
    <span class="chip">📍 Área: <b>Patologia · Fisiopatologia</b></span>
    <span class="chip">🗓 Última revisão: <b>2026-06-24</b></span>
  </div>
</div>

<!-- ══ PERGUNTA MOTIVADORA ══ -->
<section id="pergunta">
<div class="pergunta">
  <div class="plabel">Pergunta motivadora</div>
  <p>Um homem de 58 anos com hipertensão arterial e tabagismo chega ao pronto-socorro com dor torácica em aperto de início súbito. O ECG mostra supradesnivelamento de ST. Por que a placa que estava em sua coronária havia décadas se rompeu exatamente agora — e o que acontece nos minutos e horas seguintes no músculo cardíaco privado de oxigênio? Como cada distúrbio circulatório estudado neste compêndio — congestão, edema, trombose, embolia, aterosclerose e infarto — participa desse cenário?</p>
</div>
</section>

<!-- ══ DEPENDÊNCIAS ══ -->
<section id="dependencias">
<div class="dep-panel">
  <div class="dep-label">Mapa de dependências</div>
  <div class="dep-row">
    <div class="dep-group">
      <div class="dgt">Este compêndio usa</div>
      <a class="dep-item" href="../fisiopatologia/choque-circulatorio/choque-circulatorio.html">Choque Circulatório</a>
      <a class="dep-item" href="../imunologia/moleculas-sistema-imune.html#mediadores-lipidicos">Mediadores lipídicos (prostaglandinas, LTB4)</a>
      <a class="dep-item" href="../imunologia/imunidade-inata.html#inflamacao">Inflamação local — sinais cardinais</a>
    </div>
    <div class="dep-group">
      <div class="dgt">Leia antes se necessário</div>
      <a class="dep-item" href="#">Histologia vascular (endotélio, camadas arteriais)</a>
      <a class="dep-item" href="#">Fisiologia cardíaca — débito cardíaco e Frank-Starling</a>
      <a class="dep-item" href="#">Bioquímica dos lipídeos — LDL, HDL, oxidação</a>
    </div>
    <div class="dep-group">
      <div class="dgt">Materiais que dependem deste</div>
      <a class="dep-item" href="#">Farmacologia — Anticoagulantes e antiagregantes (F7)</a>
      <a class="dep-item" href="#">Farmacologia — Fármacos cardiovasculares (F4)</a>
      <a class="dep-item" href="#">Patologia — Insuficiência cardíaca</a>
    </div>
  </div>
</div>
</section>

<!-- ══ FUNDAMENTOS ══ -->
<section id="fundamentos">
<h2>Fundamentos necessários</h2>

<p>A circulação é um sistema de pressão fechado: o coração bombeia sangue contra uma resistência periférica variável, e o endotélio vascular mantém ativamente um equilíbrio entre fluxo, coagulação e tônus vasomotor. Quando qualquer um desses três pilares — pressão, parede vascular ou composição do sangue — falha, surgem as doenças circulatórias descritas neste compêndio.</p>

<p><strong>Endotélio como órgão ativo.</strong> O endotélio não é membrana passiva. Produz óxido nítrico (<em>NO</em>) e prostaciclina (PGI₂), que mantêm vasodilatação e inibem a agregação plaquetária; sintetiza <em>trombomodulina</em>, que desvia a trombina para a via anticoagulante; expressa <em>heparan-sulfato</em>, que potencializa a antitrombina III; e secreta <em>fator de von Willebrand</em> (FvW) em condições de lesão, ancorado à membrana basal. O equilíbrio entre esses papéis anticoagulante e pró-coagulante determina se um vaso responde a uma lesão com tampão hemostático controlado ou com trombose patológica.</p>

<p><strong>Forças de Starling.</strong> A troca de líquido entre o capilar e o interstício é governada por quatro pressões: pressão hidrostática capilar (P<sub>c</sub>), pressão hidrostática intersticial (P<sub>i</sub>), pressão oncótica do plasma (π<sub>c</sub>) e pressão oncótica intersticial (π<sub>i</sub>). O fluxo líquido para fora do capilar é <em>J</em> = K<sub>f</sub> × [(P<sub>c</sub> − P<sub>i</sub>) − σ(π<sub>c</sub> − π<sub>i</sub>)]. Em condições fisiológicas, o excesso que escapa para o interstício é drenado pelos linfáticos. Qualquer desequilíbrio nessas forças ou colapso da drenagem linfática gera edema.</p>

<p><strong>Cascata de coagulação — visão integrativa.</strong> A hemostasia secundária opera por duas vias convergentes no fator X ativado (Xa): a <em>via extrínseca</em> (fator tecidual + fator VII → VIIa) e a <em>via intrínseca</em> (XII → XI → IX → VIII). Ambas culminam em Xa que, com Va (complexo protrombinase), converte protrombina em trombina. A trombina cliva fibrinogênio em fibrina, ativa o fator XIII (para reticulação) e amplifica a coagulação ativando V e VIII. A fibrinólise desfaz o coágulo: ativadores do plasminogênio (tPA, uPA) geram plasmina, que degrada fibrina em produtos de degradação — os D-dímeros, biomarcadores laboratoriais de coagulação ativa.</p>
</section>

<!-- ══ CONCEITOS-CHAVE ══ -->
<section id="conceitos-chave">
<h2>Conceitos-chave</h2>
<div class="ck-grid">
  <div class="ck-card"><div class="ckt">Congestão</div><p>Aumento de sangue venoso em um tecido por drenagem prejudicada — passiva (falência cardíaca) ou ativa (hiperemia inflamatória).</p></div>
  <div class="ck-card"><div class="ckt">Edema</div><p>Acúmulo de líquido no interstício ou cavidades por desequilíbrio das forças de Starling ou drenagem linfática insuficiente.</p></div>
  <div class="ck-card"><div class="ckt">Hemostasia</div><p>Processo fisiológico de contenção de sangramento: vasoconstrição + tampão plaquetário primário + coagulação secundária.</p></div>
  <div class="ck-card"><div class="ckt">Tríade de Virchow</div><p>Os três fatores que predispõem à trombose patológica: lesão endotelial, estase/turbulência e hipercoagulabilidade.</p></div>
  <div class="ck-card"><div class="ckt">Embolia</div><p>Massa intravascular sólida, líquida ou gasosa transportada pelo sangue até impactar um vaso menor. TEP é a forma mais letal.</p></div>
  <div class="ck-card"><div class="ckt">Aterosclerose</div><p>Doença inflamatória crônica da íntima arterial: disfunção endotelial → estria lipídica → placa fibrosa → ruptura → evento agudo.</p></div>
  <div class="ck-card"><div class="ckt">Infarto</div><p>Necrose isquêmica por oclusão arterial. Branco (anemia) em órgãos terminais; vermelho (hemorrágico) em órgãos com dupla irrigação.</p></div>
  <div class="ck-card"><div class="ckt">CID</div><p>Coagulação intravascular disseminada: ativação sistêmica da hemostasia com consumo de fatores e risco de sangramento paradoxal.</p></div>
  <div class="ck-card"><div class="ckt">Reperfusão</div><p>Paradoxo: a restauração do fluxo após isquemia acrescenta dano adicional por burst de ROS, sobrecarga de Ca²⁺ e abertura do mPTP.</p></div>
</div>
</section>

</article>
</main>
</div><!-- #body-wrap -->

<script>
// ── SIDEBAR ──
const sidebar = document.getElementById('sidebar');
const bodyWrap = document.getElementById('body-wrap');
const toggleBtn = document.getElementById('toggle-btn');
const COLLAPSED = 'collapsed';

(function init(){
  if(sessionStorage.getItem('sidebar-collapsed')==='1'){
    sidebar.classList.add(COLLAPSED);
    bodyWrap.classList.add('sidebar-collapsed');
    toggleBtn.textContent='›';
  }
})();

toggleBtn.addEventListener('click',()=>{
  const c = sidebar.classList.toggle(COLLAPSED);
  bodyWrap.classList.toggle('sidebar-collapsed',c);
  toggleBtn.textContent = c ? '›' : '‹';
  sessionStorage.setItem('sidebar-collapsed', c?'1':'0');
});

// ── PROGRESS BAR ──
const pb = document.getElementById('progress-bar');
window.addEventListener('scroll',()=>{
  const t=document.documentElement.scrollTop;
  const h=document.documentElement.scrollHeight-document.documentElement.clientHeight;
  pb.style.width=(h>0?t/h*100:0)+'%';
},{passive:true});

// ── INTERSECTION OBSERVERS ──
const sideLinks = document.querySelectorAll('a.sl[href^="#"]');
const sections  = document.querySelectorAll('section[id]');

const obsActive = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    const link = document.querySelector('a.sl[href="#'+e.target.id+'"]');
    if(link) link.classList.toggle('active', e.isIntersecting);
  });
},{rootMargin:'-20% 0px -70% 0px'});

const obsInView = new IntersectionObserver(entries=>{
  entries.forEach(e=>e.target.classList.toggle('in-view',e.isIntersecting));
},{rootMargin:'-20% 0px -70% 0px'});

sections.forEach(s=>{obsActive.observe(s);obsInView.observe(s);});
</script>
</body>
</html>
